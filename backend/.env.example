# ─────────────────────────────────────────────────────────────────────────────
# SchemeChecker Backend — Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.
# ─────────────────────────────────────────────────────────────────────────────

# MongoDB Connection String (from MongoDB Atlas or local)
# Get it at: https://cloud.mongodb.com → Clusters → Connect
MONGO_URI=mongodb+srv://<username>:<password>@cluster0.xxxxx.mongodb.net/schemechecker?retryWrites=true&w=majority

# JWT Secret — any long random string
JWT_SECRET=supersecret_jwt_key_change_this_in_production_2024

# JWT Expiry — how long a token stays valid
JWT_EXPIRES_IN=7d

# Server port (Render/Railway will override this automatically)
PORT=5000

# Your frontend URL (used for CORS whitelisting)
# Example for Vercel: https://schemechecker.vercel.app
# Use http://localhost:5500 for local development with Live Server
FRONTEND_URL=http://localhost:5500

# Environment
NODE_ENV=development
